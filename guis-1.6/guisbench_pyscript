# the gguis.c file contain code to test if the pyguis is started as
# pyguis-scripter; if that is the case, the next argument is the
# Python script file. Hence the trick to run this as a /usr/bin/env
# pyguis-scripter script (see execve man page)

import gtk
import guis


def end_cb(*args):
    # guis_send just sends back a string (without any encoding)
    guis.guis_send("END")

def askadd(x,y):
    guis.guis_send("ADD \"" + guis.to_guis(x)
                   + "\" \"" + guis.to_guis(y) + "\"")

def start(welcomsg):
    global window, sumlab
    window = gtk.Window(gtk.WINDOW_TOPLEVEL)
    window.set_title("Guis Py Bench")
    vbox = gtk.VBox(gtk.FALSE,2)
    window.add(vbox)
    window.connect("destroy", end_cb)
    window.set_border_width(10)
    label = gtk.Label()
    label.set_markup('<b>Guis Bench (python)</b>\n' + guis.xml_coded(welcomsg))
    vbox.add(label)
    ## sum label
    sumlab = gtk.Label("...")
    vbox.add(sumlab)
    # create a new scrolled window.
    scrolled_window = gtk.ScrolledWindow()
    scrolled_window.set_border_width(10)
    vbox.add(scrolled_window)
    # create a table of 50 by 50 squares.
    table = gtk.Table(50, 50, gtk.FALSE)
    # set the spacing to 10 on x and 10 on y
    table.set_row_spacings(10)
    table.set_col_spacings(10)
    # pack the table into the scrolled window
    scrolled_window.add_with_viewport(table)
    ## quit button
    quitbut = gtk.Button("quit")
    quitbut.connect("clicked", end_cb)
    vbox.add(quitbut)
    # this simply creates a grid of buttons on the table
    # to demonstrate the scrolled window.
    for i in range(50):
        for j in range(50):
            buf = "but. (%d,%d)" % (i, j)
            button = gtk.Button(buf)
            table.attach(button, i, i+1, j, j+1)
            def butfun(*args):
                askadd(i,j)
            # 
            button.connect("clicked", butfun)
    print('end of start')
    window.show_all()

def displaysum(x,y,sum):
    sumlab.set_markup(('<i>%d</i> + <i>%d</i>' % (x,y))
                       + (' = <big>%d</big>' % sum))

def displayerror(message):
    sumlab.set_markup('<b>ERROR:</b> '
                      + (guis.xml_coded(message)))
    


def stopdemo():
    window.hide()
    window.destroy()
